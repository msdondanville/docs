{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Stuut Support",
  "description": "AI-powered help center for collectors, billing specialists, and finance staff.",
  "appearance": {
    "default": "light",
    "strict": false
  },
  "colors": {
    "primary": "#2F85DB",
    "light": "#5DA5E8",
    "dark": "#1B4F8F"
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/mascot.svg",
  "logo": {
    "light": "/light.svg",
    "dark": "/dark.svg",
    "href": "/"
  },
  "banner": {
    "content": "Welcome to Stuut Support — your AI-powered help center.",
    "dismissible": true
  },
  "styling": {
    "eyebrows": "section"
  },
  "navigation": {
    "pages": [
      "introduction",
      "getting-started",
      "daily-workflow",
      "emails-and-drafts",
      "ai-call-agent",
      "cash-application",
      "promise-to-pay",
      "customers-invoices",
      "payments",
      "disputes",
      "payment-portal",
      "troubleshooting",
      "glossary",
      "videos"
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Email support",
        "href": "mailto:support@stuut.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Dashboard",
      "href": "https://dashboard.stuut.co"
    }
  },
  "footer": {
    "socials": {
      "website": "https://stuut.ai"
    }
  }
}
