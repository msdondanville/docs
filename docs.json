{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Stuut Support",
  "description": "AI-powered help center for collectors, billing specialists, and finance staff.",
  "colors": {
    "primary": "#2F85DB",
    "light": "#5DA5E8",
    "dark": "#1B4F8F"
  },
  "favicon": "/mascot.svg",
  "logo": {
    "light": "/light.svg",
    "dark": "/dark.svg",
    "href": "/"
  },
  "banner": {
    "content": "Welcome to Stuut Support — your AI-powered help center.",
    "dismissible": true
  },
  "navigation": {
    "groups": [
      {
        "group": "Welcome",
        "pages": ["introduction"]
      },
      {
        "group": "📂 Collections",
        "pages": [
          "daily-workflow",
          "emails-and-drafts",
          "ai-call-agent",
          "promise-to-pay",
          "disputes",
          "payment-portal"
        ]
      },
      {
        "group": "💵 Cash App",
        "pages": [
          "cash-application",
          "payments"
        ]
      },
      {
        "group": "🖥 Platform",
        "pages": [
          "getting-started",
          "customers-invoices",
          "troubleshooting",
          "glossary"
        ]
      },
      {
        "group": "Resources",
        "pages": ["videos"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Email support",
        "href": "mailto:support@stuut.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Dashboard",
      "href": "https://dashboard.stuut.co"
    }
  },
  "footer": {
    "socials": {
      "website": "https://stuut.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  }
}
